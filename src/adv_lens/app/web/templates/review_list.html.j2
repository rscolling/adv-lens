{% extends "base.html.j2" %}
{% block title %}Pending review — ADV-Lens{% endblock %}

{% macro score_band(score) -%}
  {%- if score is none -%}
  {%- elif score >= 90 -%}score-band-90
  {%- elif score >= 80 -%}score-band-80
  {%- elif score >= 70 -%}score-band-70
  {%- elif score >= 60 -%}score-band-60
  {%- elif score >= 50 -%}score-band-50
  {%- else -%}score-band-lo
  {%- endif -%}
{%- endmacro %}

{% macro score_label(score) -%}
  {%- if score is none -%}—
  {%- elif score >= 90 -%}Clean — minimal follow-up
  {%- elif score >= 80 -%}Good — minor cleanup
  {%- elif score >= 70 -%}Minor follow-ups recommended
  {%- elif score >= 60 -%}Needs attention before next amendment
  {%- elif score >= 50 -%}Deficient — material gaps to address
  {%- else -%}Severe — defer release pending revision
  {%- endif -%}
{%- endmacro %}

{% block content %}

<section class="intro">
  <h1 style="margin:0 0 0.3em">Brochure Scoring Tool</h1>
  <p style="margin:0 0 0.8em;font-size:14px;color:var(--fg)">
    A LangGraph agent that ingests an RIA's Form ADV Part 2A brochure
    and produces a CCO-grade scorecard: fee-structure benchmarking
    against peer advisers, disciplinary disclosure flags,
    conflict-of-interest enumeration, and a redline against SEC
    plain-English expectations.
  </p>
  <ol class="workflow">
    <li><strong>Fetch</strong> the firm's most recent Part 2A brochure from
        SEC IAPD &mdash; the public disclosure portal at
        <a href="https://adviserinfo.sec.gov/" target="_blank" rel="noopener">adviserinfo.sec.gov</a>
        where every registered RIA files annually. No upload, no login.</li>
    <li><strong>Score</strong> through a LangGraph pipeline (segmenter,
        three Pydantic-typed extractors, peer retrieval, Opus redline
        writer). ~30-90s, ~$1 of Anthropic spend per run.</li>
    <li><strong>Decide</strong> &mdash; reviewer reads the
        <strong>redline</strong> (a scored compliance assessment with
        categorized findings, severity ratings, and recommendations &mdash;
        borrowed from legal review where an attorney marks up a document
        in red ink) and records approve / revise / reject. The decision
        writes one row to <code>human_reviews</code>, pinned to the
        report's SHA-256 so a regenerated report won't satisfy the same
        approval.</li>
  </ol>
  <p class="intro-links">
    <a href="https://github.com/rscolling/adv-lens#readme">README</a>
    &middot;
    <a href="https://github.com/rscolling/adv-lens/blob/main/docs/architecture.md">Architecture</a>
    &middot;
    <a href="https://github.com/rscolling/adv-lens/blob/main/docs/compliance.md">Compliance posture</a>
    &middot;
    <a href="https://github.com/rscolling/adv-lens/blob/main/docs/adr/0010-hitl-gate.md">ADR 0010 (HITL gate)</a>
    &middot;
    <a href="/docs">API reference</a>
  </p>
</section>

{% if queued_trace_id %}
<div class="flash flash-ok">
  Queued pipeline run <code>{{ queued_trace_id }}</code>. Status will appear in the
  table below — refresh to see it move from <code>queued</code> &rarr; <code>running</code>
  &rarr; <code>complete</code> (~30-90s on a real brochure).
</div>
{% endif %}
{% if error_message %}
<div class="flash flash-bad">{{ error_message }}</div>
{% endif %}

<div style="display:flex;align-items:baseline;justify-content:space-between;flex-wrap:wrap;gap:0.6em;margin:1.4em 0 0.4em">
  <h2 style="margin:0;font-size:18px">Score a brochure</h2>
  {% if not anthropic_configured %}
    <span class="warn-chip" title="Set ANTHROPIC_API_KEY in .env to run the pipeline">
      ANTHROPIC_API_KEY not set — runs will fail
    </span>
  {% endif %}
</div>

<div class="score-options">

  <section class="run-form panel">
    <h3 style="margin:0;font-size:15px">Filed brochure</h3>
    <p class="muted" style="margin:0.15em 0 0.7em;font-size:12.5px">
      Pulls from <a href="https://adviserinfo.sec.gov/" target="_blank" rel="noopener">SEC IAPD</a>
      by CRD &mdash; for benchmarking, M&amp;A diligence, or compliance review.
    </p>
    <form method="post" action="/review/runs">
      <label for="crd" class="field-label">Firm CRD number</label>
      <input id="crd" name="crd" type="text" required pattern="\d+"
             placeholder="e.g. 110181 (Brown Advisory)" class="text-input">
      <p class="field-help">
        SEC's numeric ID for an RIA (Central Registration Depository).
        Find it on each firm's IAPD page.
      </p>

      <label for="vid" class="field-label">
        Brochure version ID <span style="text-transform:none;color:var(--muted)">(optional)</span>
      </label>
      <input id="vid" name="brochure_version_id" type="text" pattern="\d+"
             placeholder="leave blank for latest" class="text-input">
      <p class="field-help">
        Firms file amended brochures over time; leave blank for current.
      </p>

      <button type="submit" class="primary-btn">Run on filed brochure</button>
    </form>
  </section>

  <section class="run-form panel">
    <h3 style="margin:0;font-size:15px">Draft brochure (pre-file)</h3>
    <p class="muted" style="margin:0.15em 0 0.7em;font-size:12.5px">
      Upload a PDF for self-review before filing &mdash; catch missing
      disclosures and unclear language while you can still amend it.
    </p>
    <form method="post" action="/review/runs/upload" enctype="multipart/form-data">
      <label for="pdf" class="field-label">Brochure PDF</label>
      <input id="pdf" name="pdf" type="file" accept="application/pdf,.pdf" required
             class="text-input" style="padding:0.4em 0.55em">
      <p class="field-help">
        Stays on this machine &mdash; nothing uploaded to SEC, Anthropic, or
        any third party until you click run. Max 25 MB.
      </p>

      <label for="firm_label" class="field-label">
        Firm label <span style="text-transform:none;color:var(--muted)">(optional)</span>
      </label>
      <input id="firm_label" name="firm_label" type="text" maxlength="64"
             placeholder="e.g. Acme Wealth Partners — for trace ID"
             class="text-input">
      <p class="field-help">
        Cosmetic only; helps you recognize the run in the list below.
      </p>

      <button type="submit" class="primary-btn">Run on draft</button>
    </form>
  </section>

</div>

<p class="muted" style="font-size:12px;margin:0.6em 0 0">
  Both paths run the same pipeline (segmenter &rarr; 3 extractors &rarr;
  peer retrieval &rarr; Opus redline writer &rarr; HITL gate). ~30-90s and
  ~$1 of Anthropic spend per run.
</p>

<h2 style="margin:1.4em 0 0.2em;font-size:18px">Pipeline runs</h2>
<p class="muted" style="margin:0 0 0.6em">
  Click a row to open the redline alongside a reviewer decision form.
  The <strong>headline</strong> column below previews the redline's one-paragraph summary.
</p>

<div class="score-legend" title="Compliance score (0–100, higher = cleaner brochure)">
  <strong>Score scale:</strong>
  <span class="legend-item"><span class="score-pill score-band-90">90+</span> Clean</span>
  <span class="legend-item"><span class="score-pill score-band-80">80–89</span> Good</span>
  <span class="legend-item"><span class="score-pill score-band-70">70–79</span> Minor follow-ups</span>
  <span class="legend-item"><span class="score-pill score-band-60">60–69</span> Needs attention</span>
  <span class="legend-item"><span class="score-pill score-band-50">50–59</span> Deficient</span>
  <span class="legend-item"><span class="score-pill score-band-lo">&lt;50</span> Severe</span>
  <span class="legend-item" style="margin-left:auto;font-style:italic">Higher = cleaner brochure</span>
</div>

<div class="panel" style="padding:0">
  {% if rows %}
  <table>
    <thead>
      <tr>
        <th>Trace</th>
        <th>CRD</th>
        <th>Status</th>
        <th>Score</th>
        <th>Findings</th>
        <th>Headline</th>
        <th>Created</th>
      </tr>
    </thead>
    <tbody>
      {% for r in rows %}
      <tr onclick="window.location='/review/{{ r.trace_id }}'" style="cursor:pointer">
        <td><a href="/review/{{ r.trace_id }}"><code>{{ r.trace_id }}</code></a></td>
        <td>{{ r.brochure_crd }}{% if r.brochure_version_id %}<span class="muted"> · v{{ r.brochure_version_id }}</span>{% endif %}</td>
        <td><span class="pill pill-{{ r.status }}">{{ r.status }}</span></td>
        <td>
          {% if r.score is not none %}
            <span class="score-pill {{ score_band(r.score) }}"
                  title="{{ score_label(r.score) }} (0–100, higher = cleaner brochure)">{{ r.score }}</span>
          {% else %}<span class="muted">—</span>{% endif %}
        </td>
        <td>{{ r.finding_count }}</td>
        <td style="max-width:36em">
          {% if r.headline %}<span title="{{ r.headline }}">{{ r.headline[:120] }}{% if r.headline|length > 120 %}…{% endif %}</span>
          {% else %}<span class="muted">—</span>{% endif %}
        </td>
        <td class="muted" style="white-space:nowrap">{{ r.created_at.strftime("%Y-%m-%d %H:%M") }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}
  <p class="empty">
    No pipeline runs yet. Kick one off via
    <code>POST /pipeline/run</code> or seed the demo with
    <code>uv run python -m adv_lens.app.web.seed</code>.
  </p>
  {% endif %}
</div>

{% endblock %}
