{% extends "base.html.j2" %}
{% block title %}Review {{ run.trace_id }} — ADV-Lens{% endblock %}

{% macro score_band(score) -%}
  {%- if score is none -%}
  {%- elif score >= 90 -%}score-band-90
  {%- elif score >= 80 -%}score-band-80
  {%- elif score >= 70 -%}score-band-70
  {%- elif score >= 60 -%}score-band-60
  {%- elif score >= 50 -%}score-band-50
  {%- else -%}score-band-lo
  {%- endif -%}
{%- endmacro %}

{% macro score_label(score) -%}
  {%- if score is none -%}—
  {%- elif score >= 90 -%}Clean — minimal follow-up
  {%- elif score >= 80 -%}Good — minor cleanup
  {%- elif score >= 70 -%}Minor follow-ups recommended
  {%- elif score >= 60 -%}Needs attention before next amendment
  {%- elif score >= 50 -%}Deficient — material gaps to address
  {%- else -%}Severe — defer release pending revision
  {%- endif -%}
{%- endmacro %}

{% block content %}

<p style="margin:0 0 0.6em">
  <a href="/review" class="back-link">&larr; All runs</a>
</p>

<div style="display:flex;align-items:baseline;gap:0.8em;margin-bottom:0.4em">
  <h1 style="margin:0">CRD {{ run.brochure_crd }}</h1>
  {% if summary.score is not none %}
    <span class="score-pill {{ score_band(summary.score) }}"
          title="{{ score_label(summary.score) }} (0–100, higher = cleaner brochure)">{{ summary.score }}</span>
  {% endif %}
  <span class="pill pill-{{ run.status }}">{{ run.status }}</span>
  <span class="muted">·  trace <code>{{ run.trace_id }}</code></span>
</div>
<p class="muted" style="margin-top:0">
  {% if run.brochure_version_id %}Brochure v{{ run.brochure_version_id }} · {% endif %}
  {{ summary.finding_count }} findings ·
  Created {{ run.created_at.strftime("%Y-%m-%d %H:%M UTC") }}
</p>

<div class="grid-2col">

  <div class="panel" style="padding:0.4em">
    {% if has_redline %}
      <iframe class="redline-frame"
              src="/review/{{ run.trace_id }}/redline.html"
              title="Redline report for {{ run.trace_id }}"></iframe>
    {% else %}
      <p class="empty">
        No redline produced for this run yet (status: {{ run.status }}).
        {% if run.error %}<br><br>Error: <code>{{ run.error }}</code>{% endif %}
      </p>
    {% endif %}
  </div>

  <div>
    <div class="panel">
      <h3 style="margin-top:0">Reviewer decision</h3>
      {% if not report_hash %}
        <p class="muted"><em>No <code>report_hash</code> on this run — decision capture disabled.</em></p>
      {% else %}
      <form class="decision-form"
            hx-post="/review/{{ run.trace_id }}/decide"
            hx-target="#decisions-panel"
            hx-swap="outerHTML"
            hx-disabled-elt="button">
        <input type="hidden" name="report_hash" value="{{ report_hash }}">

        <label>Decision</label>
        <div class="radio-group">
          <label><input type="radio" name="decision" value="approved" required> Approve</label>
          <label><input type="radio" name="decision" value="revise"> Request revision</label>
          <label><input type="radio" name="decision" value="rejected"> Reject</label>
        </div>

        <label for="reviewer">Reviewer</label>
        <input id="reviewer" type="text" name="reviewer" placeholder="jane.cco@firm.example" required>

        <label for="rationale">Rationale</label>
        <textarea id="rationale" name="rationale"
                  placeholder="Why this decision? Pinned to the report SHA-256."
                  required maxlength="4096"></textarea>

        <button type="submit">Record decision</button>
        <span class="htmx-indicator">writing audit row…</span>

        <p class="muted" style="font-size:11px;margin-top:0.8em">
          Pinned to <code>{{ report_hash[:16] }}…</code> ·
          A new run regenerates the hash and won't satisfy this approval.
        </p>
      </form>
      {% endif %}
    </div>

    {% include "decisions_panel.html.j2" %}
  </div>

</div>

{% endblock %}
